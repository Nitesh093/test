# Virtual environment
venv/

# Byte-compiled Python files
__pycache__/
*.pyc
*.pyo

# Media and static files (generated by collectstatic)
media/
static/

# Local settings
local_settings.py

# Database files
db.sqlite3

# Secret key
*.secret

# IDE and editor specific files
.vscode/
.idea/
*.swp

# Compiled Python files (e.g., .pyc)
*.pyc

# Environment variable files
.env

# Log files
*.log

# Ignore database migrations (you may want to include them)
myapp/migrations/
